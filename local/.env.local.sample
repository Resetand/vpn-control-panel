# Local control-plane environment — template, safe to commit.
# Copy to .env.local at the project root and fill in your secrets.
# .env.local is git-ignored; this sample is not.
#
# Quickstart:
#   cp local/.env.local.sample .env.local
#   # Edit .env.local — fill in VPN_TELEGRAM_BOT_TOKEN, VPN_TELEGRAM_ADMIN_IDS
#   cp local/data.local.json.sample data.local.json
#   # Edit data.local.json — set host, port, basePath, apiToken for each node
#   make init-local   # initialize node DBs, generate docker-compose
#   make run-local    # start everything

# ── 3x-ui image tag ───────────────────────────────────────────────────────────
# Global default for all nodes. Override per-node by setting XUI_IMAGE_TAG
# in local/nodes/<host>/config.env (also git-ignored).
XUI_IMAGE_TAG=v3.2.0

# ── Backup DB paths (optional) ────────────────────────────────────────────────
# If set, `make init-local INIT_ARGS=--restore` copies these files as the
# initial database for the corresponding node.
# Pattern: XUI_<HOST_UPPERCASE>_BACKUP_DB=<path>
# Example (node with "host": "eu1" in data.local.json):
#   XUI_EU1_BACKUP_DB=/path/to/eu.example.com-x-ui.db
# Can also be set in local/nodes/<host>/config.env instead of here.

# ── Control plane HTTP ────────────────────────────────────────────────────────
VPN_HOST_HTTP_PORT=8080

# ── Subscription endpoint ─────────────────────────────────────────────────────
# Links generated for clients point at this host:port.
VPN_SUBSCRIPTION_ROUTE=/sub/
VPN_SUBSCRIPTION_DOMAIN=127.0.0.1
VPN_SUBSCRIPTION_PORT=8080

# ── Telegram bot ──────────────────────────────────────────────────────────────
# Use a test bot (BotFather → /newbot) separate from production.
VPN_TELEGRAM_BOT_TOKEN=replace-me
VPN_TELEGRAM_ADMIN_IDS=replace-me
VPN_TELEGRAM_ALLOWED_USER_IDS=*
VPN_TELEGRAM_ALLOWED_CHAT_ID=

VPN_DEFAULT_VLESS_FLOW=xtls-rprx-vision

# ── Features disabled locally ─────────────────────────────────────────────────
VPN_MONITORING_ALERTS_ENABLED=false
REPORT_TELEGRAM_ENABLED=false
GEOFILES_UPDATE_ENABLED=false
BACKUP_HTTP_TOKEN=
