# Runtime
VPN_HOST_DATA_DIR=./data
VPN_HOST_HTTP_BIND=127.0.0.1
VPN_HOST_HTTP_PORT=8080
VPN_DATA_DIR=/app/data
VPN_HTTP_HOST=0.0.0.0
VPN_HTTP_PORT=8080

# VPN Subscription
VPN_SUBSCRIPTION_ROUTE=/sub/
VPN_SUBSCRIPTION_DOMAIN=example.com
VPN_SUBSCRIPTION_PORT=443
VPN_SUBSCRIPTION_CERT_PATH=/etc/letsencrypt/live/example.com

# Backup
BACKUP_HTTP_TOKEN=
BACKUP_SECRETS_SSH_KEY=
BACKUP_SECRETS_ENV_FILE=.env

# Telegram
VPN_TELEGRAM_BOT_TOKEN=replace-me
VPN_TELEGRAM_ALLOWED_USER_IDS=
VPN_TELEGRAM_ALLOWED_CHAT_ID=
VPN_TELEGRAM_ADMIN_IDS=replace-me
VPN_DEFAULT_VLESS_FLOW=xtls-rprx-vision

# Report
REPORT_TELEGRAM_ENABLED=false
REPORT_TELEGRAM_SCHEDULE="0 3 * * *"

# Geofiles automatic update
GEOFILES_UPDATE_ENABLED=false
GEOFILES_UPDATE_SCHEDULE="0 3 * * *"

# Monitoring alerts
VPN_MONITORING_ALERTS_ENABLED=false
VPN_MONITORING_POLL_INTERVAL_SECONDS=30
VPN_MONITORING_FAILURE_DURATION_SECONDS=60
VPN_MONITORING_CPU_THRESHOLD_PERCENT=90
VPN_MONITORING_RAM_THRESHOLD_PERCENT=90
VPN_MONITORING_ALERT_COOLDOWN_SECONDS=3600

# Add values for every ${{ env.VAR_NAME }} template referenced by private JSON data, eg:
# EU_3X_UI_NODE_USERNAME=admin
# EU_3X_UI_NODE_PASSWORD=replace-me
